{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-rules.md",
      ".gitignore",
      "README.md",
      "node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/login.html"
      }
    ],
    "cleanUrls": false,
    "trailingSlash": false
  }
}
